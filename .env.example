# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.

# Anthropic API key — required for Claude chat + calendar check
VITE_ANTHROPIC_API_KEY=your_key_here

# Google Calendar MCP server URL — required for conflict detection
# Run the MCP server locally (see README) then set this to its HTTP URL, e.g.:
# VITE_GOOGLE_CALENDAR_MCP_URL=http://localhost:3001/mcp
VITE_GOOGLE_CALENDAR_MCP_URL=
